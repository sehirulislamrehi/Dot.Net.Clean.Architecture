@{
    Layout = "Layout";
    ViewData["Title"] = "Role Management";
}

<!-- Content Header (Page header) -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 mt-2">
            <div class="col-sm-6">
                <p>Role Management</p>
            </div>
        </div>
    </div>
</div>

<!-- Main content -->
<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <button type="button" class="btn btn-primary mb-3 float-end"
                        data-content="@Url.Action("CreateRoleModal", "Role", new { area = "UserModule" })"
                        data-bs-target="#largeModal"
                        data-bs-toggle="modal"
                        style="cursor: pointer;">
                    Create
                </button>
            </div>
        </div>

        <!-- Search widget -->
        <div class="row">
            <div class="col-12">
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body table-responsive">
                        <div id="example1_wrapper" class="dataTables_wrapper dt-bootstrap4">
                            <div class="row">
                                <div class="col-md-12">
                                    <table id="dataGrid" class="table table-bordered table-striped dataTable dtr-inline" style="width: 100%" aria-describedby="example1_info">
                                        <thead>
                                            <tr>
                                                <th>Id</th>
                                                <th>Role</th>
                                                <th>Status</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody class="tbody-user">
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script>
        $(function () {

            $('#dataGrid').DataTable({
                processing: true,
                serverSide: true,
                pagination: 10,
                ajax: {
                    url: "@Url.Action("Data", "Role", new { area = "UserModule" })",
                    data: function (data) {
                        // data.business_unit_id = $('#search_business_unit_id').val();
                    }
                },
                order: [
                    [0, 'Desc']
                ],
                columns: [
                    {
                        data: 'id',
                        name: 'id',
                        orderable: false,
                        searchable: false,
                    },
                    {
                        data: 'name',
                        name: 'name',
                        orderable: false,
                        searchable: false,
                    },
                    {
                        data: 'status',
                        render: function (data, type, row) {

                            if(row.isActive == true){
                                return `<span class="badge badge-success">Active</span>`;
                            }
                            else{
                                return `<span class="badge badge-danger">In Active</span>`;
                            }
                        }
                    },
                    {
                        data: 'action',
                        render: function (data, type, row) {
                            let editModalURL = '@Url.Action("EditUserModal", "User", new { area = "UserModule", id = "__id__" })';
                            editModalURL = editModalURL.replace('__id__', row.id);

                            return `
                                <button type="button" class="btn btn-info float-end"
                                   data-content="${editModalURL}"
                                    data-bs-target="#largeModal"
                                    data-bs-toggle="modal"
                                    style="cursor: pointer;">
                                    <i class="fas fa-edit"></i>
                                </button>
                            `;
                        }
                    },
                ]
            });
        });
    </script>
}