@{
    Layout = "Layout";
    ViewData["Title"] = "Role Management";
}

@section Styles {
    <style>
        .permission-card {
            border: 1px solid #e5e5e5;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
            transition: 0.2s ease-in-out;
        }

            .permission-card:hover {
                box-shadow: 0 3px 12px rgba(0, 0, 0, 0.08);
            }

        .permission-group-title {
            font-weight: 600;
            font-size: 1rem;
            margin-bottom: 12px;
            border-bottom: 1px solid #eee;
            padding-bottom: 6px;
        }

        .module-item {
            padding: 10px 12px;
            border: 1px solid #f0f0f0;
            border-radius: 8px;
            margin-bottom: 10px;
            display: inherit;
        }

            .module-item .module-header {
                font-weight: 500;
                font-size: 0.95rem;
            }

        .sub-permission-box {
            margin-top: 10px;
            padding-left: 20px;
            border-left: 2px solid #dcdcdc;
        }

        .sub-permission-item {
            padding: 3px 0;
        }

            .sub-permission-item input {
                margin-right: 5px;
            }
    </style>
}

<!-- Content Header (Page header) -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 mt-2">
            <div class="col-sm-6">
                <p>Role Management</p>
            </div>
        </div>
    </div>
</div>

<!-- Main content -->
<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <button type="button" class="btn btn-primary mb-3 float-end"
                        data-content="@Url.Action("CreateRoleModal", "Role", new { area = "UserModule" })"
                        data-bs-target="#largeModal"
                        data-bs-toggle="modal"
                        style="cursor: pointer;">
                    Create
                </button>
            </div>
        </div>

        <!-- Search widget -->
        <div class="row">
            <div class="col-12">
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body table-responsive">
                        <div id="example1_wrapper" class="dataTables_wrapper dt-bootstrap4">
                            <div class="row">
                                <div class="col-md-12">
                                    <table id="dataGrid" class="table table-bordered table-striped dataTable dtr-inline" style="width: 100%" aria-describedby="example1_info">
                                        <thead>
                                            <tr>
                                                <th>Id</th>
                                                <th>Role</th>
                                                <th>Status</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody class="tbody-user">
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script>
        $(function () {

            $('#dataGrid').DataTable({
                processing: true,
                serverSide: true,
                pagination: 10,
                ajax: {
                    url: "@Url.Action("Data", "Role", new { area = "UserModule" })",
                    data: function (data) {
                        // data.business_unit_id = $('#search_business_unit_id').val();
                    }
                },
                order: [
                    [0, 'Desc']
                ],
                columns: [
                    {
                        data: 'id',
                        name: 'id',
                        orderable: false,
                        searchable: false,
                    },
                    {
                        data: 'name',
                        name: 'name',
                        orderable: false,
                        searchable: true,
                    },
                    {
                        data: 'status',
                        orderable: false,
                        searchable: false,
                        render: function (data, type, row) {

                            if(row.isActive == true){
                                return `<span class="badge badge-success">Active</span>`;
                            }
                            else{
                                return `<span class="badge badge-danger">In Active</span>`;
                            }
                        }
                    },
                    {
                        data: 'action',
                        orderable: false,
                        searchable: false,
                        render: function (data, type, row) {
                            let editModalURL = '@Url.Action("EditRoleModal", "Role", new { area = "UserModule", id = "__id__" })';
                            editModalURL = editModalURL.replace('__id__', row.id);

                            return `
                                <button type="button" class="btn btn-info float-end"
                                   data-content="${editModalURL}"
                                    data-bs-target="#largeModal"
                                    data-bs-toggle="modal"
                                    style="cursor: pointer;">
                                    <i class="fas fa-edit"></i>
                                </button>
                            `;
                        }
                    },
                ]
            });
        });
    </script>
}