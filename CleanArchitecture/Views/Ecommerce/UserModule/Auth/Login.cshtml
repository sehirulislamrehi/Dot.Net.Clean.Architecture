@model CleanArchitecture.Domain.Ecommerce.DTOs.Users.LoginRequestDTO
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Login</title>
    <link rel="stylesheet" href="~/css/bootstrap/5.3/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.3.0/css/all.min.css" asp-append-version="true" />
    <style>
        body {
            margin: 0;
            height: 100vh;
            background: radial-gradient(circle, rgb(54 167 232), #000000);
            background-size: 200% 200%;
            animation: radialLiquid 10s ease-in-out infinite;
        }

        @@keyframes radialLiquid {
            0% {
                background-position: 50% 50%;
                background-size: 200% 200%;
            }

            50% {
                background-position: 75% 75%;
                background-size: 300% 300%;
            }

            100% {
                background-position: 50% 50%;
                background-size: 200% 200%;
            }
        }


        .login-logo {
            font-size: 40px;
            font-weight: 600;
            letter-spacing: 10px;
        }

        /* Default styles for .login-box */
        .login-box {
            border: none;
            width: 576px;
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
        }

        .login-footer {
            color: whitesmoke;
        }

        /* Media query to remove width for small devices */
        @@media (max-width: 767px) {
            .login-box {
                width: auto;
                padding: 10px;
                /* Set the width to auto or any other value suitable for small screens */
            }
        }

        .logo {
            font-size: 16px !important;
            font-weight: 600 !important;
        }

        .card-body {
            background-color: unset !important;
        }

        .blur-card {
            background-color: rgba(255, 255, 255, 0.76) !important;
            filter: blur(5px);
        }

        .card {
            background-color: white !important;
        }
    </style>
</head>

<body class="hold-transition login-page">
    <div class="login-box">
        <div class="row">
            <div class="col-12">
                <div class="card p-3">

                    <div class="card-body login-card-body">
                        <div class="text-center">
                            <div class="logo my-3"><span style="font-size: 18px !important;">Login</span></div>
                        </div>
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <p class="mb-0">@error.ErrorMessage</p>
                                }
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <form action="/auth/login" class="mt-3" method="post" novalidate>
                            @Html.AntiForgeryToken()
                            <!-- Username -->
                            <div class="mb-3">
                                <div class="input-group" id="userField">
                                    <input type="text" asp-for="Username" class="form-control" placeholder="Enter your username">
                                    <div class="input-group-append">
                                        <div class="input-group-text">
                                            <span class="fas fa-user"></span>
                                        </div>
                                    </div>
                                </div>
                                <span asp-validation-for="Username" class="text-danger"></span>
                            </div>

                            <!-- Password -->
                            <div class="mb-3">
                                <div class="input-group">
                                    <input type="password" asp-for="Password" class="form-control" placeholder="Enter your password">
                                    <div class="input-group-append">
                                        <div class="input-group-text">
                                            <span class="fas fa-lock"></span>
                                        </div>
                                    </div>
                                </div>
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-8">
                                    <div class="icheck-primary">
                                        <input type="checkbox" checked id="Remember">
                                        <label for="remember">
                                            Remember
                                        </label>
                                    </div>
                                </div>
                                <div class="col-4 text-right">
                                    <button type="submit" class="btn btn-primary btn-block">Sign In</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Optional: include scripts if layout doesn't already have them -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    
</body>

</html>
